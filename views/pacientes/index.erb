<div class="space-y-6 max-w-6xl mx-auto">


    <div class="flex flex-col md:flex-row justify-between items-end gap-4 mb-8">
        <div class="flex-1 w-full">
            <h3 class="mb-4">Listado de Pacientes</h3>
            
            <form action="/pacientes" method="GET" class="relative max-w-md group">
                <input type="text" 
                    name="q" 
                    value="<%= @query %>" 
                    placeholder="Buscar paciente..." 
                    class="w-full pl-4 pr-20 py-2.5 text-[11px] font-medium border border-[var(--border-color)] rounded-lg focus:outline-none focus:border-gray-400 bg-white transition-all shadow-sm"
                >
                
                <div class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center gap-2">
                    <% if @query && !@query.empty? %>
                        <a href="/pacientes" 
                        class="p-1.5 text-gray-400 hover:text-red-500 transition-colors" 
                        title="Limpiar búsqueda">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </a>
                        <div class="w-[1px] h-4 bg-[var(--border-color)]"></div>
                    <% end %>

                    <button type="submit" class="p-1.5 text-gray-500 hover:text-black transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </button>
                </div>
            </form>


        </div>

        <a href="/pacientes/nuevo" class="btn btn-primary shadow-sm mb-[2px]">
            Nuevo Registro
        </a>
    </div>






    <div class="ui-card !p-0 overflow-hidden">
        <div class="overflow-x-auto">            
            <table class="ui-table w-full">


                <thead>
                    <tr class="bg-[var(--bg-body)] border-b border-[var(--border-color)]">
                        <th class="p-4 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)] text-center w-16">ID</th>
                        <th class="p-4 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)]">Paciente</th>
                        <th class="p-4 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)] text-center">Edad</th>
                        <th class="p-4 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)]">Contacto</th>
                        <th class="p-4 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)]">Ciudad</th>
                        <th class="p-4 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)] text-right">Acciones</th>
                    </tr>
                </thead>


                <tbody class="divide-y divide-[var(--border-color)]">

                <% if @pacientes_ds.empty? %>
                <tr>
                    <td colspan="6" class="py-20 text-center">
                        <h5 class="text-[var(--text-muted)]">No hay pacientes registrados aún</h5>
                        <p class="text-xs text-[var(--text-muted)] opacity-60">Usa el botón "Nuevo Registro" para empezar</p>
                    </td>
                </tr>
                <% end %>

                <% @pacientes_ds.each do |paciente| %>
                <tr class="hover:bg-[var(--bg-body)]/50 transition-colors">

                    <!-- ID -->
                    <td class="text-center">                    
                        <%= paciente.id_paciente %>
                    </td>

                    <!-- Paciente -->
                    <td>
                        <div>
                            <%= paciente.nombres %> <%= paciente.apellidos %>
                        </div>

                        <div>
                            <%= paciente.ocupacion || 'Sin ocupación' %>
                        </div>
                    </td>

                    <!-- Edad -->
                    <td>
                        <%= paciente.edad || '—' %>
                    </td>

                    <!-- Contacto -->
                    <td>
                        <div>
                            <%= paciente.celular %>
                        </div>
                        <div>
                            <%= paciente.email %>
                        </div>
                    </td>

                    <!-- Ciudad -->
                    <td>
                        <div>
                            <%= paciente.ciudad %>
                        </div>
                        <div>
                            <%= paciente.barrio %>
                        </div>
                    </td>

                    
                    <!-- Acciones -->
                    <td class="table-actions">
                        <div class="table-actions-group">
                            <a href="/pacientes/<%= paciente.id_paciente %>" class="table-action table-action-view">
                                Ver
                            </a>

                            <a href="/pacientes/<%= paciente.id_paciente %>/editar" class="table-action table-action-edit">
                                Editar
                            </a>

                            <form action="/pacientes/<%= paciente.id_paciente %>/eliminar" method="POST" 
                                onsubmit="return confirm('¿Confirmar eliminación?')" style="margin:0;">
                                <button type="submit" class="table-action table-action-delete">
                                    Eliminar
                                </button>
                            </form>
                        </div>
                    </td>




                </tr>
                <% end %>

                </tbody>

            </table>    
        </div>


<div class="bg-[var(--bg-body)] p-4 border-t border-[var(--border-color)] flex flex-col md:flex-row justify-between items-center gap-4">
    <span class="text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)]">
        <% if @query && !@query.empty? %>
            Encontrados <%= @pacientes_ds.pagination_record_count %> resultados para "<%= @query %>"
            <span class="mx-2">|</span>
        <% end %>
        Página <%= @pacientes_ds.current_page %> de <%= @pacientes_ds.page_count %>
    </span>
    
    <%= pagination_links(@pacientes_ds) %>
</div>


    </div>
</div>


